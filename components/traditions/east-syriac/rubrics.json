      "status": "implemented"
    },
    "esy-variable-onitha-with-qala": {
      "handled_by": "renderEastSyriac()",
      "resolution": "Extended Onitha rendering used in monastic sequences. Unlike esy-variable-seasonal-onitha (which picks a single seasonal text), this token renders the Onitha together with its appointed Qala (tone/mode indicator). Component IDs: esy-onitha-{season} for text, esy-qala-{season}-{cycle} for tone. The Qala is displayed as a rubric before the Onitha text.",
      "status": "implemented"
    },
