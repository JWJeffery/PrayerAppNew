  {
    "id": "ethiopian-saatat",
    "officeName": "The Ethiopian Saatat",
    "tradition": "Ethiopian Orthodox Tewahedo",
    "note": "The canonical hours (Saatat) of the Ethiopian Orthodox Church. The active hour is resolved dynamically by the ETH_SAATAT_HOUR_SLOT handler. Phase 2A: Lelit (21:00–06:00) split into Seventh Hour (eth-hour-7, 21:00–23:59) and Lelit proper (eth-night-hour-text, 00:00–06:00). VARIABLE_READING_ET added to Lelit and Tuat watches. v2.6.0: eth-introduction-to-every-hour prepended as mandatory opening sequence (Tselote Meweta).",
    "slots": {
      "eth-saatat-hour-slot": {
        "description": "Resolves to the appropriate canonical hour text component via ethHourInfo.hourId.",
        "time_map": {
          "06:00–09:00": { "hour_id": "eth-nigatu-hour-text",  "hour_name": "Nigatu — The Morning Watch" },
          "09:00–12:00": { "hour_id": "eth-meserkh-hour-text", "hour_name": "Meserkh — The Third Hour" },
          "12:00–15:00": { "hour_id": "eth-lika-hour-text",    "hour_name": "Lika — The Sixth Hour" },
          "15:00–18:00": { "hour_id": "eth-serkh-hour-text",   "hour_name": "Serkh — The Ninth Hour" },
          "18:00–21:00": { "hour_id": "eth-nimeat-hour-text",  "hour_name": "Nimeat — Vespers" },
          "21:00–00:00": { "hour_id": "eth-hour-7",            "hour_name": "The Seventh Hour — The First Night Watch", "phase": "2A — component text pending Phase 2B; falls back to eth-night-hour-text if component absent" },
          "00:00–06:00": { "hour_id": "eth-night-hour-text",   "hour_name": "Lelit — The Night Watch" }
        }
      },
      "eth-mazmur-slot": {
        "description": "Resolves to the appointed Psalms (Mazmur) for the active canonical hour.",
        "time_map": {
          "06:00–09:00": { "psalms": ["3",   "63",  "133"] },
          "09:00–12:00": { "psalms": ["16",  "17",  "18"]  },
          "12:00–15:00": { "psalms": ["22",  "23",  "24"]  },
          "15:00–18:00": { "psalms": ["69",  "70",  "71"]  },
          "18:00–21:00": { "psalms": ["141", "142", "143"] },
          "21:00–00:00": { "psalms": ["4",   "6",   "13"]  },
          "00:00–06:00": { "psalms": ["4",   "6",   "13"]  }
        }
      },
      "VARIABLE_READING_ET": {
        "description": "Canonical ET-tradition scripture reading. Resolved from ethHourInfo.etReading. Currently assigned for Tuat and both Lelit watches; silently skipped for all other hours.",
        "assignments": {
          "eth-tuat-hour-text":  { "citation": "1CLEM_ET 1:1-20",  "title": "The Tuat Reading — 1 Clement" },
          "eth-hour-7":          { "citation": "HERM_ET 1:1-10",   "title": "The Lelit Reading — The Shepherd of Hermas" },
          "eth-night-hour-text": { "citation": "HERM_ET 1:1-10",   "title": "The Lelit Reading — The Shepherd of Hermas" }
        }
      }
    },
    "sequence": [
      "eth-introduction-to-every-hour",
      "eth-basalios-prayer",
      "eth-saatat-hour-slot",
      "eth-mazmur-slot",
      "VARIABLE_READING_ET",
      "eth-saints-commemoration",
      "comm-lords-prayer"
    ]
  }
]