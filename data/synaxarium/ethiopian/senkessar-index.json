  "entry_file_schema": {
    "description": "Each reading_id resolves to a file at data/synaxarium/ethiopian/{month-slug}/{day}.json. That file must conform to the following schema.",
    "schema": {
      "id": "string — matches reading_id from this index (e.g. senkessar-meskerem-1)",
      "ethiopian_date": "string — e.g. '1 Meskerem'",
      "gregorian_equivalent": "string — approximate Gregorian date, e.g. 'September 11'",
      "feast_title": "string or null — name of the principal feast or commemoration",
      "saints": [
        {
          "name": "string",
          "epithet": "string or null — e.g. 'the Apostle', 'of Alexandria'",
          "tradition": "string — e.g. 'Ethiopian Orthodox', 'Coptic Orthodox'",
          "martyrdom": "boolean",
          "narrative": "string — the full Senkessar hagiographical reading for this saint"
        }
      ],
      "closing_doxology": "string or null — optional doxological formula appended after the reading"
    }
  }
