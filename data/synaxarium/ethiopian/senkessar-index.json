{
  "meta": {
    "name": "Senkessar — Index of the Ethiopian Synaxarium",
    "id": "SENKESSAR_INDEX",
    "description": "Maps each day of the 13-month Ethiopian calendar to its appointed Senkessar entry IDs. Entries are keyed by Ethiopian month name and day number. Each day may carry multiple entries (primary saint, secondary saint, feast). The 'reading_id' field is the component/narrative ID that will be resolved by renderOffice() via the eth-synaxarium-reading component.",
    "calendar_system": "Ethiopian (Ge'ez) — 12 months of 30 days + Pagume (intercalary month of 5 or 6 days)",
    "month_names": [
      "Meskerem", "Tikimt", "Hidar", "Tahsas",
      "Tir", "Yekatit", "Megabit", "Miyazya",
      "Ginbot", "Sene", "Hamle", "Nehase", "Pagume"
    ],
    "version": "1.0 — structural template (Phase 1)",
    "note": "Entry IDs follow the pattern: senkessar-{month-slug}-{day}. Narrative text files will reside at data/synaxarium/ethiopian/{month-slug}/{day}.json."
  },

